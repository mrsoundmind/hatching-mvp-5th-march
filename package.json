  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "npm run check",
    "db:push": "drizzle-kit push",
    "qa:full": "npm run lint && npm run typecheck && npm run build",
    "qa:autonomy": "npm run test:dto && npm run test:integrity && npm run test:memory && npm run test:memory:restart && npm run test:recovery && npm run test:injection && npm run test:tone && npm run eval:routing && npm run gate:conductor && npm run gate:safety && npm run perf:samples && npm run gate:performance && npm run eval:bench && npm run eval:alive && npm run eval:smartness",
    "qa:autonomy:live": "npm run test:ws-race && npm run test:ws-reconnect",
    "evidence:export": "tsx scripts/export-evidence.ts",
    "eval:bench": "tsx scripts/eval-bench.ts",
    "eval:routing": "tsx scripts/eval-routing.ts",
    "eval:alive": "tsx scripts/eval-alive.ts",
    "eval:smartness": "tsx scripts/eval-smartness-improvement.ts",

    "gate:safety": "tsx scripts/gate-safety.ts",
    "perf:samples": "tsx scripts/generate-performance-samples.ts",
    "gate:performance": "tsx scripts/gate-performance.ts",
    "report:autonomy": "tsx scripts/report-autonomy.ts",
    "test:integrity": "tsx scripts/test-conversation-integrity.ts",
    "test:memory": "tsx scripts/test-memory-persistence.ts",
    "test:memory:restart": "tsx scripts/test-memory-persistence.ts --write-only && tsx scripts/test-memory-persistence.ts --verify-only",
